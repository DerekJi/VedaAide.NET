{
  "Veda": {
    "StorageProvider": "CosmosDb",
    "EmbeddingProvider": "AzureOpenAI",
    "LlmProvider": "AzureOpenAI",

    "AzureOpenAI": {
      "Endpoint": "",
      "ApiKey": "",
      "EmbeddingDeployment": "text-embedding-3-small",
      "ChatDeployment": "gpt-4o-mini"
    },
    "DocumentIntelligence": {
      "Endpoint": "",
      "ApiKey": ""
    },
    "Vision": {
      "Enabled": true
    },
    "CosmosDb": {
      "Endpoint": "",
      "AccountKey": "",
      "DatabaseName": "VedaAide",
      "ChunksContainerName": "VectorChunks",
      "CacheContainerName": "SemanticCache",
      "EmbeddingDimensions": 1536
    },
    "DeepSeek": {
      "BaseUrl": "https://api.deepseek.com/v1",
      "ApiKey": "",
      "ChatModel": "deepseek-chat"
    },
    "Security": {
      "ApiKey": "",
      "AdminApiKey": "",
      "AllowedOrigins": "*"
    },

    "SemanticCache": {
      "Enabled": false,
      "SimilarityThreshold": 0.95,
      "TtlSeconds": 3600
    },

    "Rag": {
      "SimilarityDedupThreshold": 0.95,
      "HallucinationSimilarityThreshold": 0.3,
      "DefaultMinSimilarity": 0.3,
      "EnableSelfCheckGuard": false,
      "HybridRetrievalEnabled": true,
      "VectorWeight": 0.7,
      "KeywordWeight": 0.3,
      "FusionStrategy": "Rrf"
    },
    "Semantics": {
      "VocabularyFilePath": ""
    },
    "DataSources": {
      "FileSystem": {
        "Enabled": false,
        "Path": "",
        "Extensions": [ ".txt", ".md", ".pdf", ".jpg", ".jpeg", ".png", ".webp", ".tiff", ".bmp" ]
      },
      "BlobStorage": {
        "Enabled": false,
        "ConnectionString": "",
        "AccountUrl": "",
        "ContainerName": "my-docs",
        "Prefix": "",
        "Extensions": [ ".txt", ".md", ".pdf", ".jpg", ".jpeg", ".png", ".webp", ".tiff", ".bmp" ]
      },
      "AutoSync": {
        "Enabled": false,
        "IntervalMinutes": 60
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
